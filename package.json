{
  "name": "paytm-craft",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/craft-api",
    "packages/craft-bridge",
    "packages/craft-bridge-vscode",
    "packages/craft-realtime"
  ],
  "scripts": {
    "dev:sync": "node scripts/mock-yjs-sync-server.mjs",
    "dev": "next dev -p 3000",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "build": "npm run db:generate -w @paytm-craft/api && next build",
    "build:with-engine": "npm run build:engine && npm run build",
    "verify:engine": "node scripts/verify-craft-engine-artifacts.mjs",
    "verify:golden": "node scripts/verify-golden-native-render.mjs",
    "verify:editor": "node scripts/verify-native-editor.mjs",
    "verify:migration": "node scripts/verify-migration.mjs",
    "verify:persistence": "node scripts/verify-persistence.mjs",
    "dev:api": "node scripts/dev-api-stack.mjs",
    "db:up": "docker compose up -d postgres redis minio",
    "db:down": "docker compose down",
    "db:setup": "node scripts/db-setup.mjs",
    "stack:up": "docker compose up -d --build",
    "stack:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "stack:down": "docker compose down",
    "stack:setup": "node scripts/stack-setup.mjs",
    "storage:setup": "node scripts/storage-setup.mjs",
    "api:dev": "npm run dev -w @paytm-craft/api",
    "sync:dev": "npm run dev -w @paytm-craft/realtime",
    "dev:remote": "node scripts/dev-remote-stack.mjs",
    "verify:backend": "node scripts/verify-backend.mjs",
    "verify:remote": "node scripts/verify-remote.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "verify:production": "node scripts/verify-production-deploy.mjs",
    "verify:canvas-chrome": "node scripts/verify-canvas-chrome.mjs",
    "verify:legacy-cleanup": "node scripts/verify-legacy-cleanup.mjs",
    "verify:ci": "node scripts/verify-ci.mjs",
    "verify:ci-gate": "node scripts/verify-ci-gate.mjs",
    "verify:api-contracts": "node scripts/verify-api-contracts.mjs",
    "verify:tracks-sync": "node scripts/verify-tracks-sync.mjs",
    "verify:editor-gate": "node scripts/verify-editor-gate.mjs",
    "verify:stack-live-gate": "node scripts/verify-stack-live-gate.mjs",
    "verify:migration-gate": "node scripts/verify-migration-gate.mjs",
    "verify:docker-stack-gate": "node scripts/verify-docker-stack-gate.mjs",
    "verify:release-stack-gate": "node scripts/verify-release-stack-gate.mjs",
    "verify:stack": "node scripts/verify-stack.mjs",
    "verify:stack:live:contract": "node scripts/verify-stack-live-contract.mjs",
    "verify:stack:live": "tsx scripts/verify-stack-live.ts",
    "verify:tracks": "node scripts/verify-tracks-index.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "tsx --test 'src/lib/**/__tests__/*.test.ts' 'src/engine/**/__tests__/*.test.ts' && npm run test -w @paytm-craft/bridge",
    "test:all": "npm run build:engine:check && npm test && npm run verify:engine && npm run verify:golden",
    "build:engine": "bash scripts/build-craft-engine.sh",
    "build:engine:check": "cd packages/craft-engine && cargo test",
    "render:native": "packages/craft-engine/target/release/craft-render",
    "setup:browsers": "playwright install chromium",
    "bundle:dom-extractor": "esbuild src/lib/webImport/domExtractor.ts --bundle --platform=browser --format=iife --global-name=__craftDomExtract --outfile=src/lib/webImport/server/domExtractor.bundle.js",
    "craft-bridge": "node packages/craft-bridge/cli.mjs",
    "craft:setup": "bash scripts/craft-setup.sh",
    "bridge:pack": "npm run pack:check -w @paytm-craft/bridge",
    "bridge:publish": "node scripts/publish-bridge.mjs",
    "bridge:publish:live": "node scripts/publish-bridge.mjs --publish",
    "extension:vendor": "node scripts/package-craft-extension.mjs",
    "extension:pack": "node scripts/package-craft-extension.mjs --vsix"
  },
  "postinstall": "npm run db:generate -w @paytm-craft/api",
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@cursor/sdk": "^1.0.18",
    "@paytm-craft/bridge": "*",
    "clipper2-js": "^1.2.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "node-html-parser": "^7.1.0",
    "openfig-core": "^0.3.7",
    "playwright": "^1.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "ws": "^8.21.0"
  }
}
