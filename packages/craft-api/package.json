{
  "name": "@paytm-craft/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./db": "./src/db.ts",
    "./auth/password": "./src/auth/password.ts",
    "./auth/resolveAuth": "./src/auth/resolveAuth.ts",
    "./auth/apiTokenScope": "./src/auth/apiTokenScope.ts",
    "./auth/apiTokenResourceScope": "./src/auth/apiTokenResourceScope.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "tsx --test 'src/**/__tests__/*.test.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.24",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
