generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
  guest
}

enum ApiTokenScope {
  read
  write
}

enum OAuthProvider {
  google
  github
}

model User {
  id           String   @id
  email        String   @unique
  displayName  String   @map("display_name")
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")

  fileVersions      FileVersion[]     @relation("FileVersionAuthor")
  sessions          Session[]
  apiTokens         ApiToken[]
  assets            Asset[]           @relation("AssetAuthor")
  workspaceMembers  WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[] @relation("InviteSender")
  teamMembers       TeamMember[]
  oauthAccounts     OAuthAccount[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  email             String?
  createdAt         DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model ApiToken {
  id              String          @id
  userId          String          @map("user_id")
  name            String
  tokenHash       String          @unique @map("token_hash")
  tokenPrefix     String          @map("token_prefix")
  scope           ApiTokenScope   @default(write)
  resourceScopes  String[]        @default([]) @map("resource_scopes")
  expiresAt       DateTime?       @map("expires_at")
  lastUsedAt      DateTime?       @map("last_used_at")
  revokedAt       DateTime?       @map("revoked_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model Team {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  members    TeamMember[]
  workspaces Workspace[]

  @@map("teams")
}

model TeamMember {
  teamId    String        @map("team_id")
  userId    String        @map("user_id")
  role      WorkspaceRole
  createdAt DateTime      @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Workspace {
  id        String   @id
  teamId    String   @map("team_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  files   File[]
  assets  Asset[]
  members WorkspaceMember[]
  invites WorkspaceInvite[]

  @@unique([teamId, slug])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  createdAt   DateTime      @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id              String        @id
  workspaceId     String        @map("workspace_id")
  email           String
  role            WorkspaceRole
  invitedByUserId String        @map("invited_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  acceptedAt      DateTime?     @map("accepted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedByUserId], references: [id])

  @@unique([workspaceId, email])
  @@index([email])
  @@map("workspace_invites")
}

model File {
  id           String   @id
  workspaceId  String   @map("workspace_id")
  name         String
  documentJson Json?    @map("document_json")
  revision     String   @default("1")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  comments  Comment[]
  versions  FileVersion[]
  yjsState  FileYjsState?

  @@index([workspaceId, updatedAt(sort: Desc)])
  @@map("files")
}

model FileYjsState {
  fileId        String   @id @map("file_id")
  stateBase64   String   @map("state_base64") @db.Text
  updatedAt     DateTime @updatedAt @map("updated_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_yjs_states")
}

model FileVersion {
  id              String   @id
  fileId          String   @map("file_id")
  name            String
  documentJson    Json     @map("document_json")
  createdAt       DateTime @default(now()) @map("created_at")
  createdByUserId String   @map("created_by_user_id")

  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author User @relation("FileVersionAuthor", fields: [createdByUserId], references: [id])

  @@index([fileId, createdAt(sort: Desc)])
  @@map("file_versions")
}

model Comment {
  id           String   @id
  fileId       String   @map("file_id")
  body         String
  resolved     Boolean  @default(false)
  x            Float?
  y            Float?
  parentNodeId String?  @map("parent_node_id")
  frameId      String?  @map("frame_id")
  createdAt    DateTime @default(now()) @map("created_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, createdAt])
  @@map("comments")
}

model Asset {
  id              String   @id
  workspaceId     String   @map("workspace_id")
  storageKey      String   @map("storage_key")
  fileName        String   @map("file_name")
  mime            String
  byteSize        BigInt   @map("byte_size")
  width           Int?
  height          Int?
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation("AssetAuthor", fields: [createdByUserId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("assets")
}
