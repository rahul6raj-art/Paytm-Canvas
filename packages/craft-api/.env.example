DATABASE_URL=postgresql://craft:craft@localhost:5432/craft?schema=public
REDIS_URL=redis://localhost:6379
CRAFT_API_PORT=4000

# --- Development (default) ---
CRAFT_API_ENV=development
CRAFT_API_ALLOW_ANON=1
CRAFT_API_RBAC=1

# --- Production profile ---
# CRAFT_API_ENV=production
# CRAFT_API_ALLOW_ANON=0
# CRAFT_API_COOKIE_SECURE=1
# CRAFT_API_TRUST_PROXY=1
# CRAFT_API_CORS_ORIGIN=https://your-app.example.com

# CRAFT_APP_URL=http://localhost:3000

# --- OAuth (Google + GitHub) ---
# CRAFT_API_PUBLIC_URL=http://localhost:4000
# CRAFT_OAUTH_STATE_SECRET=change-me-in-production
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Callback: http://localhost:4000/v1/auth/oauth/google/callback

# --- SMTP (optional — invite + password reset emails) ---
# CRAFT_SMTP_HOST=localhost
# CRAFT_SMTP_PORT=1025
# CRAFT_SMTP_FROM=Paytm Craft <noreply@craft.local>
# With docker mailpit: CRAFT_SMTP_HOST=mailpit CRAFT_SMTP_PORT=1025

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=craft-assets
S3_ACCESS_KEY=craft
S3_SECRET_KEY=craftcraft
S3_REGION=us-east-1
