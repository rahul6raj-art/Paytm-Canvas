# Production environment template (Track 25)
# Copy to secrets manager / kubectl / fly secrets — NEVER commit filled values.
#
# Providers used in examples:
#   Postgres — Neon (or RDS)
#   Redis    — Upstash
#   Objects  — Cloudflare R2
#   SMTP     — Resend (smtp.resend.com)
#   Web      — Vercel or deploy/web/Dockerfile

# --- Shared (craft-api + craft-realtime) ---
DATABASE_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/craft?sslmode=require
REDIS_URL=rediss://default:TOKEN@upstash-host:6379

# --- craft-api ---
CRAFT_API_ENV=production
CRAFT_API_ALLOW_ANON=0
CRAFT_API_COOKIE_SECURE=1
CRAFT_API_TRUST_PROXY=1
CRAFT_API_RBAC=1
CRAFT_API_CORS_ORIGIN=https://craft.example.com
CRAFT_APP_URL=https://craft.example.com

# Cloudflare R2 (S3-compatible API)
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://assets.craft.example.com
S3_BUCKET=craft-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Invite email (Resend SMTP — optional but recommended in prod)
CRAFT_SMTP_HOST=smtp.resend.com
CRAFT_SMTP_PORT=587
CRAFT_SMTP_FROM=Paytm Craft <noreply@craft.example.com>
CRAFT_SMTP_USER=resend
CRAFT_SMTP_PASS=

# --- craft-realtime ---
CRAFT_SYNC_ENV=production
CRAFT_SYNC_ALLOW_ANON=0
CRAFT_SYNC_DEBOUNCE_MS=3000

# --- Next.js web (Vercel project env or Docker build-args) ---
NEXT_PUBLIC_PAYTM_CRAFT_MODE=remote
NEXT_PUBLIC_PAYTM_CRAFT_API_URL=https://api.craft.example.com/v1
NEXT_PUBLIC_PAYTM_CRAFT_SYNC_URL=wss://sync.craft.example.com/yjs
NEXT_PUBLIC_PAYTM_CRAFT_STORAGE_URL=https://assets.craft.example.com
NEXT_PUBLIC_PAYTM_CRAFT_RENDERER=native

# --- Post-cutover smoke (local shell, not deployed) ---
# CRAFT_API_TOKEN=craft_pat_…
