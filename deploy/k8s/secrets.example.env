# Copy to a local file (never commit) and load into Kubernetes:
# kubectl -n craft create secret generic craft-backend --from-env-file=./secrets.prod.env

DATABASE_URL=postgresql://USER:PASS@postgres-host:5432/craft?schema=public
REDIS_URL=redis://redis-host:6379

S3_ENDPOINT=https://s3.amazonaws.com
S3_PUBLIC_URL=https://cdn.example.com
S3_BUCKET=craft-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional invite email
CRAFT_SMTP_HOST=
CRAFT_SMTP_PORT=587
CRAFT_SMTP_FROM=Paytm Craft <noreply@example.com>
CRAFT_SMTP_USER=
CRAFT_SMTP_PASS=
