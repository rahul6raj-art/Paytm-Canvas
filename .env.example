# Local open-source models (Llama, DeepSeek, Qwen, etc.) via Ollama — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI cloud models (optional — set when using GPT models in Generate with AI)
# OPENAI_API_KEY=

# Figma REST API import (link / file key). Team-wide token — users do not need a personal token in the UI.
# Create at https://www.figma.com/developers/api#access-tokens then restart `npm run dev`.
FIGMA_ACCESS_TOKEN=

# If verify/import shows "fetch failed" on corporate VPN, set to true for local dev only:
# FIGMA_SKIP_TLS_VERIFY=true
