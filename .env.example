# Paytm Craft — optional env (copy to `.env.local`)

# --- AI (optional) ---
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=

# --- Figma import (optional) ---
# FIGMA_ACCESS_TOKEN=
# FIGMA_SKIP_TLS_VERIFY=true

# --- MCP proxy (canvas Integrations panel) ---
# Allow stdio MCP servers on production/self-hosted (default: dev only)
# MCP_STDIO_ENABLED=1

# --- Canvas renderer ---
NEXT_PUBLIC_PAYTM_CRAFT_RENDERER=native

# --- Persistence mode ---
# local (default) | api (mock /api/v1) | remote (craft-api)
# NEXT_PUBLIC_PAYTM_CRAFT_MODE=local

# --- Remote / full stack (npm run dev:remote) ---
# NEXT_PUBLIC_PAYTM_CRAFT_MODE=remote
# NEXT_PUBLIC_PAYTM_CRAFT_API_URL=http://localhost:4000/v1
# NEXT_PUBLIC_PAYTM_CRAFT_SYNC_URL=ws://localhost:4001/yjs
# NEXT_PUBLIC_PAYTM_CRAFT_STORAGE_URL=http://localhost:9000/craft-assets

# --- Mock API dev (npm run dev:api) ---
# NEXT_PUBLIC_PAYTM_CRAFT_MODE=api
# NEXT_PUBLIC_PAYTM_CRAFT_SYNC_URL=ws://localhost:3001/yjs
# PAYTM_CRAFT_MOCK_API_PERSIST=1

# --- API token smoke test (npm run verify:stack:live) ---
# Create via POST /v1/auth/tokens while signed in, then:
# CRAFT_API_TOKEN=craft_pat_…
# CRAFT_VERIFY_SKIP_LIVE=1   # skip npm run verify:stack:live when Docker stack is down

# --- Production cutover (Track 25) ---
# See deploy/production/env.example.env and deploy/production/README.md
# Neon DATABASE_URL, Upstash REDIS_URL, R2 S3_*, Resend CRAFT_SMTP_*, HTTPS NEXT_PUBLIC_* URLs
